{
  "name": "arxatec-ui",
  "version": "0.1.11",
  "description": "React component library for building Arxatec product UIs—built on established ecosystem libraries for a consistent, efficient workflow. More at https://arxatec.net.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "react",
    "react-components",
    "ui",
    "design-system",
    "component-library",
    "tailwindcss",
    "tailwind-v4",
    "shadcn",
    "shadcn-ui",
    "radix",
    "radix-ui",
    "accessible",
    "typescript",
    "esm",
    "lucide-react",
    "cva",
    "arxatec"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arxatec-engine/arxatec-ui.git"
  },
  "bugs": {
    "url": "https://github.com/arxatec-engine/arxatec-ui/issues"
  },
  "homepage": "https://arxatec.net",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./sidebar": {
      "types": "./dist/exports/sidebar.d.ts",
      "import": "./dist/sidebar.js",
      "default": "./dist/sidebar.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "types": "./dist/exports/index.d.ts",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.build.json && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && node scripts/merge-lib-styles.mjs",
    "prepublishOnly": "npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:preview": "npm run build-storybook && serve storybook-static -s -l 6006",
    "storybook:serve-static": "serve storybook-static -s -l 6006"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
